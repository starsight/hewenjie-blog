---
import BaseLayout from './BaseLayout.astro';
import QuoteLine from '../components/QuoteLine.astro';
import { formatPostStats, getPostStats } from '../lib/postStats';
import { absoluteUrl, site } from '../lib/site';

const { entry } = Astro.props;
const { title, pubDate, updatedDate, tags, categories } = entry.data as {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  categories: string[];
};
const date = new Intl.DateTimeFormat('zh-CN', { dateStyle: 'medium' }).format(pubDate);
const stats = formatPostStats(getPostStats(entry.body));
const categorySet = new Set(categories.map((category) => category.toLowerCase()));
const visibleTags = tags.filter((tag) => !categorySet.has(tag.toLowerCase()));
const description = entry.data.description ?? title;
const canonicalUrl = absoluteUrl(entry.data.permalink);
const keywords = [...new Set([...categories, ...tags])];
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  inLanguage: 'zh-CN',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl
  },
  author: {
    '@type': 'Person',
    name: site.author,
    url: site.authorUrl
  },
  publisher: {
    '@type': 'Person',
    name: site.author,
    url: site.authorUrl
  },
  keywords,
  image: absoluteUrl(site.defaultImage),
  url: canonicalUrl
};
---

<BaseLayout
  title={`${title} | ${site.name}`}
  description={description}
  type="article"
  canonicalPath={entry.data.permalink}
  structuredData={structuredData}
>
  <article class="post">
    <p class="post-meta">{date} · {stats}</p>
    <h1>{title}</h1>
    <div class="chips">
      {categories.map((category) => <a class="chip" href={`/categories/${encodeURIComponent(category)}/`}>{category}</a>)}
      {visibleTags.map((tag) => <a class="chip" href={`/tags/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
    </div>
    <QuoteLine scenes={['post']} compact />
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>
