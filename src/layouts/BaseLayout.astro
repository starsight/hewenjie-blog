---
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '贺文杰的博客',
  description = '技术、生活与旧文归档。'
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f7f7f3;
        --paper: #ffffff;
        --text: #232522;
        --muted: #6f766d;
        --line: #deded6;
        --accent: #1d6f5f;
        --accent-soft: #e2f0ea;
        --code: #f1f3ef;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.72;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        max-width: 1040px;
        margin: 0 auto;
        padding: 26px 22px 18px;
      }

      .brand {
        color: var(--text);
        font-size: 20px;
        font-weight: 750;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        font-size: 14px;
      }

      main {
        max-width: 1040px;
        margin: 0 auto;
        padding: 22px;
      }

      .page-title {
        margin: 24px 0 8px;
        font-size: clamp(34px, 6vw, 62px);
        line-height: 1.06;
        letter-spacing: 0;
      }

      .page-subtitle,
      .post-meta {
        color: var(--muted);
      }

      .post-list {
        display: grid;
        gap: 14px;
        margin-top: 32px;
      }

      .post-item {
        display: block;
        padding: 20px 0;
        border-top: 1px solid var(--line);
      }

      .post-item h2 {
        margin: 0 0 8px;
        color: var(--text);
        font-size: 24px;
        line-height: 1.28;
        letter-spacing: 0;
      }

      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
      }

      .chip {
        border-radius: 999px;
        background: var(--accent-soft);
        color: #185648;
        padding: 3px 9px;
        font-size: 13px;
      }

      .post {
        max-width: 820px;
        margin: 0 auto;
        padding-bottom: 56px;
      }

      .post h1 {
        margin: 28px 0 12px;
        font-size: clamp(32px, 5vw, 52px);
        line-height: 1.12;
        letter-spacing: 0;
      }

      .post-content {
        margin-top: 34px;
        font-size: 17px;
      }

      .post-content h2,
      .post-content h3,
      .post-content h4 {
        margin: 34px 0 12px;
        line-height: 1.28;
        letter-spacing: 0;
      }

      .post-content img {
        max-width: 100%;
        height: auto;
      }

      .post-content pre,
      .post-content code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      }

      .post-content pre {
        overflow-x: auto;
        padding: 16px;
        background: var(--code);
        border-radius: 6px;
      }

      .post-content code {
        background: var(--code);
        border-radius: 4px;
        padding: 2px 5px;
      }

      .post-content pre code {
        background: transparent;
        padding: 0;
      }

      .post-content figure.highlight {
        overflow-x: auto;
        margin: 22px 0;
        padding: 0;
        background: var(--code);
        border-radius: 6px;
      }

      .post-content figure.highlight table {
        width: 100%;
        border-collapse: collapse;
      }

      .post-content figure.highlight pre {
        margin: 0;
        padding: 12px;
        background: transparent;
      }

      .post-content .gutter {
        width: 1%;
        user-select: none;
        color: #8d948b;
        border-right: 1px solid var(--line);
      }

      .post-content .code {
        width: 99%;
      }

      .term-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 28px;
      }

      .term-grid a {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 12px;
        background: var(--paper);
      }

      .term-count {
        color: var(--muted);
        font-size: 13px;
      }

      .about-hero {
        display: grid;
        grid-template-columns: 96px minmax(0, 1fr);
        align-items: center;
        gap: 24px;
        margin-top: 20px;
      }

      .about-hero img {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--line);
        background: var(--paper);
      }

      .about-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 14px;
        margin-top: 16px;
        color: var(--muted);
        font-size: 14px;
      }

      .about-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1px;
        margin: 34px 0;
        border: 1px solid var(--line);
        background: var(--line);
      }

      .about-stats div {
        display: grid;
        gap: 2px;
        padding: 16px;
        background: var(--paper);
      }

      .about-stats strong {
        font-size: 24px;
        line-height: 1.2;
      }

      .about-stats span {
        color: var(--muted);
        font-size: 14px;
      }

      .about-section {
        max-width: 820px;
        border-top: 1px solid var(--line);
        padding: 24px 0 4px;
      }

      .about-section h2 {
        margin: 0 0 12px;
        font-size: 24px;
        letter-spacing: 0;
      }

      .timeline {
        display: grid;
        gap: 8px;
        padding-left: 0;
        list-style: none;
      }

      .timeline span {
        display: inline-block;
        min-width: 136px;
        color: var(--muted);
      }

      @media (max-width: 680px) {
        .site-header {
          align-items: flex-start;
          flex-direction: column;
        }

        main {
          padding: 18px;
        }

        .about-hero {
          grid-template-columns: 1fr;
        }

        .about-stats {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
  </body>
</html>
