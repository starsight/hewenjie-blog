---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatPostDate, formatPostStats, getPostStats } from '../../lib/postStats';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const groups = Map.groupBy(posts, (post) => String(post.data.pubDate.getFullYear()));
---

<BaseLayout title="归档 | 贺文杰的博客">
  <h1 class="page-title">归档</h1>
  {[...groups.entries()].map(([year, yearPosts]) => (
    <section>
      <h2>{year}</h2>
      <div class="post-list">
        {yearPosts.map((post) => (
          <a class="post-item" href={post.data.permalink}>
            <p class="post-meta">
              {formatPostDate(post.data.pubDate)} · {formatPostStats(getPostStats(post.body))}
            </p>
            <h2>{post.data.title}</h2>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
