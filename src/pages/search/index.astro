---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const postCount = (await getCollection('blog')).length;
---

<BaseLayout
  title="搜索 | 贺文杰的博客"
  description="搜索贺文杰博客中的 Android、工程实践、个人写作与旧文归档。"
  canonicalPath="/search/"
  pagefind
>
  <section class="search-page">
    <h1 class="page-title">搜索</h1>
    <p class="page-subtitle">在 {postCount} 篇文章中搜索标题、正文和关键词。</p>
    <pagefind-searchbox
      placeholder="搜索文章"
      max-results="12"
      show-sub-results
      autofocus
    ></pagefind-searchbox>
  </section>
</BaseLayout>
