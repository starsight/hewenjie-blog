---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const categories = [...new Set(posts.flatMap((post) => post.data.categories))];
  return categories.map((category) => ({ params: { category }, props: { category } }));
}

const { category } = Astro.props;
const posts = (await getCollection('blog'))
  .filter((post) => post.data.categories.includes(category))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${category} | 贺文杰的博客`}>
  <h1 class="page-title">{category}</h1>
  <section class="post-list">
    {posts.map((post) => (
      <a class="post-item" href={post.data.permalink}>
        <p class="post-meta">{post.data.pubDate.toISOString().slice(0, 10)}</p>
        <h2>{post.data.title}</h2>
      </a>
    ))}
  </section>
</BaseLayout>
