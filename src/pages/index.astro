---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatPostDate, formatPostStats, getPostStats } from '../lib/postStats';
import { absoluteUrl, site } from '../lib/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const postsWithMeta = posts.map((post) => {
  const categorySet = new Set(post.data.categories.map((category) => category.toLowerCase()));
  return {
    post,
    stats: formatPostStats(getPostStats(post.body)),
    visibleTags: post.data.tags.filter((tag) => !categorySet.has(tag.toLowerCase()))
  };
});
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: absoluteUrl('/'),
  description: site.description,
  inLanguage: 'zh-CN',
  author: {
    '@type': 'Person',
    name: site.author,
    url: site.authorUrl
  }
};
---

<BaseLayout structuredData={structuredData}>
  <section>
    <h1 class="page-title">文章</h1>
  </section>
  <section class="post-list">
    {postsWithMeta.map(({ post, stats, visibleTags }) => (
      <a class="post-item" href={post.data.permalink}>
        <p class="post-meta">
          {formatPostDate(post.data.pubDate)} · {stats}
        </p>
        <h2>{post.data.title}</h2>
        {post.data.description && <p>{post.data.description}</p>}
        <div class="chips">
          {post.data.categories.slice(0, 2).map((category) => <span class="chip">{category}</span>)}
          {visibleTags.slice(0, 4).map((tag) => <span class="chip">#{tag}</span>)}
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
