---
const nav = [
  { href: '/', label: '文章' },
  { href: '/archive/', label: '归档' },
  { href: '/tags/', label: '标签' },
  { href: '/categories/', label: '分类' },
  { href: '/about/', label: '关于' }
];
---

<header class="site-header">
  <a class="brand" href="/">贺文杰的博客</a>
  <nav aria-label="主导航">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
